# Local MongoDB:
# MONGO_URI=mongodb://localhost:27017/employee_management

# Atlas (use mongodb+srv from Atlas UI — not the atlas-sql query URL):
# MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.example.mongodb.net/employee_management?retryWrites=true&w=majority&appName=your-app

PORT=4000
JWT_SECRET=change_this_to_a_long_random_string
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CORS_ORIGINS=http://localhost:4200,http://localhost:8080,http://127.0.0.1:4200
